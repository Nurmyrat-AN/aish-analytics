<% function money(value) { return Number(value || 0).toLocaleString("ru-RU", { minimumFractionDigits: 2,
    maximumFractionDigits: 2 }); } %>

    <%- include("../layouts/main", { title, activeMenu, body: ` <section class="page">
        <div class="page-header">
            <div>
                <h1>Dead Stock</h1>
                <p>Товары с остатком, которые давно или вообще не продавались</p>
            </div>

            <form method="GET" action="/bi/dead-stock" class="period-form">
                <select class="input" name="days" onchange="this.form.submit()">
                    <option value="90" ${days===90 ? "selected" : "" }>90 дней</option>
                    <option value="180" ${days===180 ? "selected" : "" }>180 дней</option>
                    <option value="365" ${days===365 ? "selected" : "" }>365 дней</option>
                    <option value="730" ${days===730 ? "selected" : "" }>730 дней</option>
                </select>
            </form>
        </div>

        ${include("./partials/bibar", { active: 'dead-stock', period })}

        <div class="card">
            <h3>Мёртвый товар</h3>

            <table class="table">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th>Остаток</th>
                        <th>Последняя продажа</th>
                        <th>Дней без продажи</th>
                    </tr>
                </thead>
                <tbody>
                    ${rows.map(x => `
                    <tr>
                        <td>${x.urun_adi}</td>
                        <td>${money(x.current_stock)}</td>
                        <td>${x.last_sale_date || "Нет продаж"}</td>
                        <td class="text-danger">${x.days_without_sale || "Никогда"}</td>
                    </tr>
                    `).join("")}
                </tbody>
            </table>
        </div>
        </section>
        `
        }) %>