<% function money(value) { return Number(value || 0).toLocaleString("ru-RU", { minimumFractionDigits: 2,
  maximumFractionDigits: 2 }); } %>

  <%- include("../layouts/main", { title, activeMenu, body: ` <section class="page">
    <div class="page-header">
      <div>
        <h1>Slow Moving</h1>
        <p>Товары, которые давно не продавались, но есть на складе</p>
      </div>

      <form method="GET" action="/bi/slow-moving" class="period-form">
        <select class="input" name="days" onchange="this.form.submit()">
          <option value="30" ${days===30 ? "selected" : "" }>30 дней</option>
          <option value="60" ${days===60 ? "selected" : "" }>60 дней</option>
          <option value="90" ${days===90 ? "selected" : "" }>90 дней</option>
          <option value="180" ${days===180 ? "selected" : "" }>180 дней</option>
          <option value="365" ${days===365 ? "selected" : "" }>365 дней</option>
        </select>
      </form>
    </div>

    ${include("./partials/bibar", { active: 'slow-moving', period: days })}

    <div class="card">
      <h3>Медленно продающиеся товары</h3>

      <table class="table">
        <thead>
          <tr>
            <th>Товар</th>
            <th>Остаток</th>
            <th>Последняя продажа</th>
            <th>Дней без продажи</th>
            <th>Продано за период</th>
            <th>Выручка за период</th>
          </tr>
        </thead>
        <tbody>
          ${rows.map(x => `
          <tr>
            <td>${x.urun_adi}</td>
            <td>${money(x.current_stock)}</td>
            <td>${x.last_sale_date || "Нет продаж"}</td>
            <td class="text-danger">${x.days_without_sale || "—"}</td>
            <td>${money(x.qty_sold)}</td>
            <td>${money(x.revenue)}</td>
          </tr>
          `).join("")}
        </tbody>
      </table>
    </div>
    </section>
    `
    }) %>